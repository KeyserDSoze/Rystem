{
  "compilerOptions": {
    "noEmitOnError": true,
    "noImplicitAny": false,
    "sourceMap": true,
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "module": "commonjs",
    "esModuleInterop": true,
    "types": ["node", "mocha"],
    "skipLibCheck": true
  },
  "include": [ "./**/*.ts", "./*.ts" ],
  "exclude": [ "./models/**/*.*", "./setup/**/*.*" ],
  "compileOnSave": true
}